# ============================================
# 环境变量配置模板
# ============================================
# 复制此文件为 .env 并根据实际环境修改配置
# cp .env.example .env

# ============================================
# 应用版本号（用于前端展示等）
# ============================================
APP_VERSION=v0.2.1

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password
DB_TYPE=mysql

# ============================================
# Neo4j 配置
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ============================================
# LLM API 配置
# ============================================
LLM_API_KEY=your_api_key_here
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
LLM_CONTENT_PREVIEW_CHARS=1000
# 最大输出 token 数（诊断报告含多表格时需较大值，建议 8192 或 16384）
LLM_MAX_TOKENS=8192

# ============================================
# Dome 服务配置
# ============================================
# dome-datasource 服务地址
DOME_DATASOURCE_BASE_URL=http://your-host:port/api/dome-datasource

# dome-scheduler 服务地址
DOME_SCHEDULER_BASE_URL=http://your-host:port/api/dome-scheduler

# ============================================
# Dome-Auth 认证配置
# ============================================
# 认证服务地址（从 dome.datasource.base-url 或 dome.scheduler.base-url 中提取基础URL）
DOME_AUTH_BASE_URL=http://your-host:port

# 客户端凭证
DOME_AUTH_CLIENT_ID=sword
DOME_AUTH_CLIENT_SECRET=sword_secret

# 登录凭证
DOME_AUTH_USERNAME=admin
DOME_AUTH_PASSWORD=your_password

# 租户ID（可选，如果系统开启租户模式）
DOME_AUTH_TENANT_ID=000000

# 是否启用自动认证（默认：true）
DOME_AUTH_ENABLED=true

# 静态 token（可选，如果配置了静态 token，将优先使用静态 token）
# 格式：bearer <token>，token 是动态变化的，需要定期更新
DOME_AUTH_TOKEN=

# ============================================
# 其他配置
# ============================================
# 默认目标数据源ID（当目标数据源不存在时使用）
DEFAULT_TARGET_DATASOURCE_ID=

# Ontology 模型选择: schema (收费系统) or powergrid (电网规划)
ONTOLOGY_MODEL=schema

# 存储类型: file (本地文件系统), neo4j, or hybrid (关系型数据库 + 图数据库)
STORAGE_TYPE=hybrid
# 图数据库类型: neo4j | falkordb（当 STORAGE_TYPE=neo4j 或 hybrid 时生效）
STORAGE_GRAPH_TYPE=neo4j

# Doris 支持：将 DB_TYPE 设为 doris，DB_PORT 通常为 9030
# DB_TYPE=doris
# DB_PORT=9030

# FalkorDB 配置（当 STORAGE_GRAPH_TYPE=falkordb 时使用）
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379
# FALKORDB_GRAPH=mypalantir

# 系统 schema 文件路径（可选，用于工作空间管理）
SCHEMA_SYSTEM_FILE_PATH=./ontology/schema-system.yaml